<style>

/* ==========================================================
   BRANDTRACK HELP CENTER — HOME PAGE
   Full-viewport two-column layout (mockup v2)
   ========================================================== */

/* ── BASE ── */
html, body {
  background: #000;
  color: #fff;
  font-family: 'Space Grotesk', sans-serif;
}

/* ── HOME PAGE: full-viewport, hide header/footer ── */
body.template-home_page {
  overflow: hidden;
}

body.template-home_page .header,
body.template-home_page header,
body.template-home_page .footer,
body.template-home_page footer {
  display: none !important;
}

body.template-home_page .main-content,
body.template-home_page #main-content-outer,
body.template-home_page .main-content > .container {
  padding: 0 !important;
  margin: 0 !important;
  max-width: none !important;
  width: 100% !important;
}

/* ── MAIN GRID ── */
.bt-main {
  display: grid;
  grid-template-columns: 400px 1fr;
  height: 100vh;
}

/* ── LEFT PANEL ── */
.bt-left {
  background:
    radial-gradient(ellipse at 30% 85%, rgba(116,85,253,0.35) 0%, transparent 55%),
    radial-gradient(ellipse at 80% 10%, rgba(80,50,180,0.18) 0%, transparent 50%),
    #080614;
  padding: 40px 40px 48px;
  display: flex;
  flex-direction: column;
  gap: 28px;
  overflow-y: auto;
  overflow-x: visible;
  scrollbar-width: none;
}
.bt-left::-webkit-scrollbar { display: none; }

/* Logo */
.bt-home-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  margin-bottom: -4px;
}
.bt-home-logo-img {
  height: 32px;
  width: auto;
  display: block;
}

/* Language toggle (kept for backward-compat, hidden now it's floating) */
.bt-lang-toggle { display: none; }

/* Title */
.bt-title {
  font-size: 48px;
  font-weight: 800;
  line-height: 1.08;
  color: #fff;
  margin: 0;
  letter-spacing: -0.03em;
}

/* Search box — pill shape, light gray against dark panel */
.bt-search-wrap {
  position: relative;
  width: 100%;
  display: flex;
  align-items: center;
  gap: 10px;
  background: rgba(255,255,255,0.11);
  border: 1px solid rgba(255,255,255,0.16);
  border-radius: 999px;
  padding: 14px 20px;
  transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
  box-sizing: border-box;
}
.bt-search-wrap:focus-within {
  background: rgba(255,255,255,0.15);
  border-color: rgba(255,255,255,0.3);
}

/* Magnifying glass icon */
.bt-search-icon {
  flex-shrink: 0;
  color: rgba(255,255,255,0.6);
  pointer-events: none;
  display: block;
}

/* Zendesk form — fully transparent, takes remaining space */
.bt-search-wrap .search,
.bt-search-wrap .search-full {
  flex: 1 !important;
  display: flex !important;
  align-items: center !important;
  background: transparent !important;
  border: none !important;
  border-radius: 0 !important;
  padding: 0 !important;
  margin: 0 !important;
  box-shadow: none !important;
  width: auto !important;
  min-width: 0 !important;
  gap: 8px !important;
  position: relative !important;
}

.bt-search-wrap input[type="search"],
.bt-search-wrap input[type="text"] {
  flex: 1 !important;
  background: transparent !important;
  border: none !important;
  outline: none !important;
  box-shadow: none !important;
  color: #fff !important;
  font-family: 'Space Grotesk', sans-serif !important;
  font-size: 16px !important;
  font-weight: 400 !important;
  min-width: 0 !important;
  padding: 0 !important;
  width: 100% !important;
  -webkit-appearance: none !important;
  appearance: none !important;
  letter-spacing: -0.01em !important;
}
.bt-search-wrap input[type="search"]::-webkit-search-cancel-button,
.bt-search-wrap input[type="search"]::-webkit-search-decoration {
  -webkit-appearance: none !important;
  appearance: none !important;
  display: none !important;
}

.bt-search-wrap input::placeholder {
  color: rgba(255,255,255,0.38) !important;
}

/* Submit button hidden (submit=false) */
.bt-search-wrap .search-full button[type="submit"],
.bt-search-wrap .search button[type="submit"] {
  display: none !important;
}

/* Clear button — hidden by default, shown only when input has value */
.bt-search-wrap .clear-button {
  background: rgba(255,255,255,0.12) !important;
  border: none !important;
  border-radius: 999px !important;
  color: rgba(255,255,255,0.7) !important;
  width: 24px !important;
  height: 24px !important;
  flex-shrink: 0 !important;
  display: none !important;
  align-items: center !important;
  justify-content: center !important;
  cursor: pointer !important;
  padding: 0 !important;
  transition: background 0.15s, color 0.15s !important;
}
.bt-search-wrap .search-has-value .clear-button {
  display: flex !important;
}
.bt-search-wrap .clear-button:hover {
  background: rgba(255,255,255,0.22) !important;
  color: #fff !important;
}

/* Instant search dropdown — positioned below the pill */
.bt-search-wrap [role="listbox"],
.bt-search-wrap .autocomplete-suggestions,
.bt-search-wrap [class*="suggestion"] {
  position: absolute !important;
  top: calc(100% + 8px) !important;
  left: 0 !important;
  right: 0 !important;
  z-index: 9999 !important;
  background: #0e0e14 !important;
  border: 1px solid rgba(255,255,255,0.14) !important;
  border-radius: 14px !important;
  overflow: hidden !important;
  box-shadow: 0 18px 50px rgba(0,0,0,0.6) !important;
}

/* Popular label */
.bt-popular-label {
  font-size: 12px;
  font-weight: 700;
  color: rgba(255,255,255,0.4);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin: 0;
}

/* Tags */
.bt-tags {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.bt-tag {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 10px;
  padding: 13px 16px;
  font-size: 14px;
  color: rgba(255,255,255,0.8);
  cursor: pointer;
  transition: all 0.2s;
  text-decoration: none;
  display: block;
  font-family: 'Space Grotesk', sans-serif;
}

.bt-tag:hover {
  background: rgba(116,85,253,0.15);
  border-color: rgba(116,85,253,0.45);
  color: #fff;
}

/* ── RIGHT PANEL — WHITE ── */
.bt-right {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  height: 100vh;
  background: #ffffff;
  border-left: 1px solid #e8e8e8;
  overflow-y: auto;
}

/* ── CATEGORY CARDS ── */
.bt-cat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  cursor: pointer;
  text-decoration: none;
  color: #1a1a1a;
  border-right: 1px solid #e8e8e8;
  border-bottom: 1px solid #e8e8e8;
  transition: background 0.2s;
  padding: 36px 24px;
  min-height: calc(100vh / 3);
  position: relative;
}

/* Remove double borders */
.bt-cat-card:nth-child(3n)   { border-right: none; }
.bt-cat-card:nth-child(n+7)  { border-bottom: none; }

.bt-cat-card:hover {
  background: rgba(116,85,253,0.05);
}

/* Icon — purple mask-image technique */
.bt-cat-icon {
  display: block;
  width: 48px;
  height: 48px;
  flex-shrink: 0;
  background-color: #7455FD;
  -webkit-mask-size: contain;
  -webkit-mask-repeat: no-repeat;
  -webkit-mask-position: center;
  mask-size: contain;
  mask-repeat: no-repeat;
  mask-position: center;
  transition: transform 0.2s, background-color 0.2s;
}
.bt-cat-card:hover .bt-cat-icon {
  background-color: #6040ee;
  transform: scale(1.08);
}

/* Name */
.bt-cat-name {
  font-size: 14px;
  font-weight: 600;
  color: #1a1a1a;
  text-align: center;
  line-height: 1.35;
  font-family: 'Space Grotesk', sans-serif;
  letter-spacing: -0.01em;
  max-width: 160px;
}

/* ── ICON MAPPING — mask-image (nth-child = Zendesk category order) ── */
.bt-right .bt-cat-card:nth-child(1)  .bt-cat-icon { -webkit-mask-image: url({{asset 'PRIMEROS-PASOS.svg'}}); mask-image: url({{asset 'PRIMEROS-PASOS.svg'}}); }
.bt-right .bt-cat-card:nth-child(2)  .bt-cat-icon { -webkit-mask-image: url({{asset 'CUENTAS.svg'}}); mask-image: url({{asset 'CUENTAS.svg'}}); }
.bt-right .bt-cat-card:nth-child(3)  .bt-cat-icon { -webkit-mask-image: url({{asset 'APP.svg'}}); mask-image: url({{asset 'APP.svg'}}); }
.bt-right .bt-cat-card:nth-child(4)  .bt-cat-icon { -webkit-mask-image: url({{asset 'BRANDTRACK-BOX.svg'}}); mask-image: url({{asset 'BRANDTRACK-BOX.svg'}}); }
.bt-right .bt-cat-card:nth-child(5)  .bt-cat-icon { -webkit-mask-image: url({{asset 'MUSICA.svg'}}); mask-image: url({{asset 'MUSICA.svg'}}); }
.bt-right .bt-cat-card:nth-child(6)  .bt-cat-icon { -webkit-mask-image: url({{asset 'anuncios.svg'}}); mask-image: url({{asset 'anuncios.svg'}}); }
.bt-right .bt-cat-card:nth-child(7)  .bt-cat-icon { -webkit-mask-image: url({{asset 'SIGNAGE.svg'}}); mask-image: url({{asset 'SIGNAGE.svg'}}); }
.bt-right .bt-cat-card:nth-child(8)  .bt-cat-icon { -webkit-mask-image: url({{asset 'TECNICOS.svg'}}); mask-image: url({{asset 'TECNICOS.svg'}}); }
.bt-right .bt-cat-card:nth-child(9)  .bt-cat-icon { -webkit-mask-image: url({{asset 'PLANS.svg'}}); mask-image: url({{asset 'PLANS.svg'}}); }
.bt-right .bt-cat-card:nth-child(10) .bt-cat-icon { -webkit-mask-image: url({{asset 'LICENCIAS.svg'}}); mask-image: url({{asset 'LICENCIAS.svg'}}); }

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  body.template-home_page { overflow: auto; }

  .bt-main {
    grid-template-columns: 1fr;
    height: auto;
  }
  .bt-left { padding: 36px 24px 40px; }
  .bt-title { font-size: 38px; }

  .bt-right {
    height: auto;
    border-left: none;
    border-top: 1px solid #e8e8e8;
    grid-template-columns: repeat(2, 1fr);
  }
  .bt-cat-card { min-height: 160px; }

  .bt-cat-card:nth-child(3n)  { border-right: 1px solid #e8e8e8; }
  .bt-cat-card:nth-child(n+7) { border-bottom: 1px solid #e8e8e8; }
  .bt-cat-card:nth-child(2n)  { border-right: none; }
  .bt-cat-card:nth-child(n+9) { border-bottom: none; }
}

@media (max-width: 768px) {
  .bt-right { grid-template-columns: 1fr !important; }

  .bt-cat-card {
    min-height: 88px !important;
    flex-direction: row !important;
    justify-content: flex-start !important;
    padding: 20px 28px !important;
    gap: 18px !important;
    border-right: none !important;
    border-bottom: 1px solid #e8e8e8 !important;
  }
  .bt-cat-card:last-child { border-bottom: none !important; }
  .bt-cat-card:nth-child(n)   { border-right: none !important; }
  .bt-cat-card:nth-child(n+7) { border-bottom: 1px solid #e8e8e8 !important; }

  .bt-cat-icon { width: 36px !important; height: 36px !important; flex-shrink: 0; }
  .bt-cat-name { text-align: left !important; max-width: none !important; font-size: 15px !important; }
}


/* ==========================================================
   SEARCH DROPDOWN — DARK MODE (all pages)
   ========================================================== */

:root {
  --bt-dd-bg:     #0b0b0f;
  --bt-dd-bg2:    #141420;
  --bt-dd-border: rgba(255,255,255,.14);
  --bt-dd-text:   rgba(255,255,255,.92);
  --bt-dd-muted:  rgba(255,255,255,.62);
  --bt-dd-violet: #7455FD;
}

html body [class*="searchbox-suggest"],
html body [class*="searchboxSuggest"],
html body [class*="instant-search"],
html body [class*="instantSearch"],
html body [class*="search-results"],
html body [class*="searchResults"],
html body [class*="autocomplete"],
html body [class*="auto-complete"],
html body [class*="suggestion"],
html body [class*="suggestions"],
html body [role="listbox"],
html body [data-search-results],
html body [data-suggestions] {
  background: var(--bt-dd-bg) !important;
  border: 1px solid var(--bt-dd-border) !important;
  border-radius: 16px !important;
  box-shadow: 0 18px 50px rgba(0,0,0,.55) !important;
  color: var(--bt-dd-text) !important;
}

html body [class*="searchbox-suggest"] *,
html body [class*="instant-search"] *,
html body [class*="search-results"] *,
html body [class*="autocomplete"] *,
html body [class*="suggestions"] *,
html body [data-search-results] * {
  color: var(--bt-dd-text) !important;
}

html body [class*="searchbox-suggest"] li,
html body [class*="instant-search"] li,
html body [class*="search-results"] li,
html body [class*="autocomplete"] li,
html body [class*="suggestion"],
html body [role="option"] {
  background: transparent !important;
  border-top: 1px solid var(--bt-dd-border) !important;
}

html body [class*="searchbox-suggest"] li:hover,
html body [class*="instant-search"] li:hover,
html body [class*="search-results"] li:hover,
html body [class*="autocomplete"] li:hover,
html body [class*="suggestion"]:hover,
html body [role="option"]:hover,
html body [aria-selected="true"] {
  background: var(--bt-dd-bg2) !important;
}

html body [class*="searchbox-suggest"] a,
html body [class*="instant-search"] a,
html body [class*="search-results"] a,
html body [class*="autocomplete"] a,
html body [class*="suggestion"] a {
  color: var(--bt-dd-violet) !important;
  text-decoration: none !important;
}

html body [class*="searchbox-suggest"] mark,
html body [class*="instant-search"] mark,
html body [class*="search-results"] mark,
html body [class*="autocomplete"] mark,
html body [class*="searchbox-suggest"] strong,
html body [class*="instant-search"] strong,
html body [class*="search-results"] strong {
  color: var(--bt-dd-violet) !important;
  background: transparent !important;
  font-weight: 700 !important;
}

html body [class*="breadcrumb"],
html body [class*="search-result-breadcrumb"],
html body [class*="searchResultBreadcrumb"],
html body [class*="search-result-meta"],
html body [class*="searchResultMeta"] {
  display: none !important;
}

.search-full [role="combobox"] ~ *,
.search-full [aria-expanded] ~ * {
  background: #0b0b0f !important;
  border-radius: 12px !important;
  border: 1px solid rgba(255,255,255,0.14) !important;
}


/* ==========================================================
   SEARCH RESULTS PAGE
   ========================================================== */

body[class*="search"] main,
body[class*="search"] .container,
body[class*="search"] .container-divider,
body[class*="search"] .search-results {
  background: #000 !important;
}

.search-results-sidebar,
.search-results-column + .search-results-sidebar {
  display: none !important;
}

.search-results-column,
.search-results .search-results-column {
  width: 100% !important;
  max-width: 980px;
  margin: 0 auto !important;
  padding: 28px 18px 60px !important;
}

.search-results-column h1,
.search-results-column h2,
.search-results-column .search-results-subheading {
  color: #fff !important;
}

.search-results-list,
.search-results-column ul {
  list-style: none !important;
  padding: 0 !important;
  margin: 16px 0 0 !important;
}

.search-result,
.search-results-list li {
  padding: 14px 0 !important;
  margin: 0 !important;
  background: transparent !important;
  border: 0 !important;
  border-bottom: 1px solid rgba(255,255,255,0.10) !important;
  border-radius: 0 !important;
}

.search-result:last-child,
.search-results-list li:last-child {
  border-bottom: 0 !important;
}

.search-result a,
.search-result-title a,
.search-results-list a {
  color: #7455FD !important;
  text-decoration: none !important;
  font-weight: 700 !important;
}

.search-result a:hover,
.search-result-title a:hover,
.search-results-list a:hover {
  text-decoration: underline !important;
}

.search-result-description,
.search-result-snippet,
.search-results-list p,
.search-results-list span {
  color: rgba(255,255,255,0.85) !important;
}

.search-result-breadcrumbs,
.search-result-breadcrumbs a {
  color: rgba(255,255,255,0.45) !important;
  text-decoration: none !important;
}

.search-results input[type="search"],
.search-results input[type="text"],
.search-results .search input {
  background: rgba(255,255,255,0.08) !important;
  color: #fff !important;
  border: 1px solid rgba(255,255,255,0.14) !important;
  border-radius: 999px !important;
}

.search-results input::placeholder {
  color: rgba(255,255,255,0.55) !important;
}

.search-results .search-results-count,
.search-results .search-results-heading,
.search-results .search-results-subheading {
  padding: 0 !important;
  margin: 0 0 12px 0 !important;
  color: rgba(255,255,255,0.9) !important;
  font-weight: 700 !important;
  background: transparent !important;
  border: 0 !important;
  box-shadow: none !important;
  border-radius: 0 !important;
}

</style>
